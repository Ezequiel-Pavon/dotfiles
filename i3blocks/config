# i3blocks config - Howard

command=/usr/share/i3blocks/$BLOCK_NAME
separator_block_width=15
markup=none

[volume]
instance=Master
interval=once
signal=10
separator=true
color=#FFFFFF

[memory]
label=RAM
interval=10
separator=true
color=#FFFFFF

[cpu_usage]
label=CPU
interval=5
min_width=CPU: 100.00%
separator=true
color=#FFFFFF

[temperature]
label=TEMP
interval=10
separator=true
color=#FFFFFF

[disk]
label=DISK
instance=/
interval=30
separator=true
color=#FFFFFF

[iface]
instance=eth0
color=#FFFFFF
interval=10
separator=true

[wifi]
interval=10
separator=true
color=#FFFFFF

[time]
command=date '+%d/%m %H:%M'
interval=5
color=#FFFFFF
separator=false
